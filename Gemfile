source "https://rubygems.org"

# GitHub Pages meta-gem pins Jekyll and the plugin set that Pages supports,
# and bundles jekyll-remote-theme so `remote_theme:` works.
gem "github-pages", group: :jekyll_plugins
gem "jekyll-remote-theme"
gem "jekyll-include-cache"

# Needed on Ruby 3.x where these were unbundled from the stdlib.
gem "webrick"
gem "csv"
gem "base64"
gem "bigdecimal"
