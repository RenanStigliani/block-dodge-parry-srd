# URL of the deployed Cloudflare Worker that files GitHub issues on behalf of readers.
# See worker/README.md for how to deploy it. Leave unset to disable the "report text" widget.
PUBLIC_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# Cloudflare Turnstile site key (public, safe to commit/embed). Leave unset to hide the
# CAPTCHA widget (not recommended for the live site).
PUBLIC_TURNSTILE_SITE_KEY=
